def _on_passive_shell_branch_clicked(self, branch: str):
    """
    Phase 2B only:
    passive shell does not own behavior yet.
    It only expands the corresponding legacy area where possible.
    """
    try:
        if not hasattr(self, "accordion_sidebar") or self.accordion_sidebar is None:
            return

        legacy_map = {
            "find": "find",
            "all": "dates",
            "folders": "folders",
            "dates": "dates",
            "videos": "videos",
            "locations": "locations",
            "people_merge_review": "people",
            "people_unnamed": "people",
            "people_show_all": "people",
        }

        target = legacy_map.get(branch)
        if target and hasattr(self.accordion_sidebar, "_expand_section"):
            self.accordion_sidebar._expand_section(target)
    except Exception as e:
        print(f"[{self.__class__.__name__}] Passive shell click failed: {branch} → {e}")


def _on_passive_activity_requested(self):
    """
    Phase 2B only:
    keep this passive, no new ownership.
    """
    try:
        if hasattr(self, "main_window") and self.main_window:
            if hasattr(self.main_window, "_open_activity_center_from_sidebar"):
                self.main_window._open_activity_center_from_sidebar()
    except Exception as e:
        print(f"[{self.__class__.__name__}] Passive activity request failed: {e}")
```

