def _build_passive_shell(self):
    self.left_shell_container = QWidget(self)
    self.left_shell_container.setObjectName("GoogleLeftShell")
    self.left_shell_container.setMinimumWidth(280)
    self.left_shell_container.setMaximumWidth(300)
    self.left_shell_container.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Expanding)

    self.left_shell_layout = QVBoxLayout(self.left_shell_container)
    self.left_shell_layout.setContentsMargins(8, 8, 8, 8)
    self.left_shell_layout.setSpacing(8)

    self.search_sidebar = SearchSidebar(self.left_shell_container)

    # Passive only: no new routing ownership in this phase
    self.search_sidebar.selectBranch.connect(self._on_passive_shell_branch_clicked)
    self.search_sidebar.openActivityCenterRequested.connect(self._on_passive_activity_requested)

    self.legacy_container = QGroupBox("Legacy Tools")
