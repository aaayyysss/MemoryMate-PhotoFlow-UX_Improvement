        self.body_layout.setSpacing(4)
        self.body.setVisible(expanded)

        root.addWidget(self.header_btn)
        root.addWidget(self.body)

    def _toggle(self):
        self._expanded = self.header_btn.isChecked()
        self.body.setVisible(self._expanded)

