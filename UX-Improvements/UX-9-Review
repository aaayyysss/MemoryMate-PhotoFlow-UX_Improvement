            list_item = QListWidgetItem(title)
            list_item.setData(256, item)
            self.list_widget.addItem(list_item)

    def _on_selection_changed(self, current, previous):
        if not current:
            self.left_preview.clear()
            self.right_preview.clear()
            return

        item = current.data(256) or {}
        self.left_preview.setText(
            f"Cluster: {item.get('left_id', '')}\n"
            f"Count: {item.get('left_count', '?')}\n"
            f"Reason: {item.get('reason', '')}\n"
            f"Score: {item.get('score', '')}"
        )
        self.right_preview.setText(
            f"Cluster: {item.get('right_id', '')}\n"
            f"Count: {item.get('right_count', '?')}\n"
            f"Reason: {item.get('reason', '')}\n"
            f"Score: {item.get('score', '')}"
        )

    def _accept_selected(self):
        item = self.list_widget.currentItem()
        if not item:
            return
        data = item.data(256) or {}
        self.mergeAccepted.emit(str(data.get("left_id", "")), str(data.get("right_id", "")))

    def _reject_selected(self):
        item = self.list_widget.currentItem()
        if not item:
            return
        data = item.data(256) or {}
        self.mergeRejected.emit(str(data.get("left_id", "")), str(data.get("right_id", "")))


