from __future__ import annotations

from dataclasses import dataclass
from typing import List, Dict, Any, Optional
import math


@dataclass
class MergeCandidate:
    left_id: str
    right_id: str
    score: float
    reason: str
    left_count: int
    right_count: int


class PeopleMergeEngine:
    """
    Lightweight merge-suggestion engine for UX-9.
    Uses cluster size, naming, and optional centroid/co-occurrence hints.
    Safe bridge phase, no schema rewrite required.
    """

    def __init__(self):
        pass

    def build_candidates(self, people_items: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        normalized = []
        for item in list(people_items or []):
            if not isinstance(item, dict):
                continue
            pid = item.get("id") or item.get("person_id") or item.get("label")
            label = item.get("label") or item.get("name") or str(pid)
            count = int(item.get("count", 0))
            centroid = item.get("centroid")
            unnamed = bool(item.get("unnamed", False) or str(label).lower().startswith("face_"))
            normalized.append({
                "id": str(pid),
                "label": str(label),
                "count": count,
                "centroid": centroid,
                "unnamed": unnamed,
            })

        candidates: List[MergeCandidate] = []

        for i in range(len(normalized)):
            for j in range(i + 1, len(normalized)):
                left = normalized[i]
                right = normalized[j]

                if left["id"] == right["id"]:
                    continue

                score, reason = self._score_pair(left, right)
                if score >= 0.60:
                    candidates.append(
                        MergeCandidate(
                            left_id=left["id"],
                            right_id=right["id"],
                            score=score,
                            reason=reason,
                            left_count=left["count"],
                            right_count=right["count"],
                        )
                    )

        candidates = sorted(candidates, key=lambda c: c.score, reverse=True)
        return [
            {
                "left_id": c.left_id,
                "right_id": c.right_id,
                "score": c.score,
                "reason": c.reason,
                "left_count": c.left_count,
                "right_count": c.right_count,
                "label": f"{c.left_id} ↔ {c.right_id} ({c.reason}, {c.score:.2f})",
            }
            for c in candidates[:20]
        ]

    def _score_pair(self, left: Dict[str, Any], right: Dict[str, Any]) -> tuple[float, str]:
        score = 0.0
        reasons = []

        # Small clusters are more suspicious
        if left["count"] <= 3:
            score += 0.15
            reasons.append("left small")
        if right["count"] <= 3:
            score += 0.15
            reasons.append("right small")

        # Two unnamed clusters are more likely review-worthy
        if left["unnamed"] and right["unnamed"]:
            score += 0.20
            reasons.append("both unnamed")

        # Similar size often means candidate split identity
        diff = abs(left["count"] - right["count"])
        if diff <= 2:
            score += 0.10
            reasons.append("similar size")

        # Optional centroid similarity if available
        sim = self._centroid_similarity(left.get("centroid"), right.get("centroid"))
        if sim is not None:
            if sim >= 0.85:
                score += 0.35
                reasons.append("very similar centroid")
            elif sim >= 0.78:
                score += 0.20
                reasons.append("similar centroid")

        return min(score, 0.99), ", ".join(reasons) if reasons else "review candidate"

    def _centroid_similarity(self, a: Optional[list], b: Optional[list]) -> Optional[float]:
        if not a or not b or len(a) != len(b):
            return None
        try:
            dot = sum(float(x) * float(y) for x, y in zip(a, b))
            na = math.sqrt(sum(float(x) * float(x) for x in a))
            nb = math.sqrt(sum(float(y) * float(y) for y in b))
            if na == 0 or nb == 0:
                return None
            return dot / (na * nb)
        except Exception:
            return None
