def get_merge_suggestions(self):
    """
    UX-9A / UX-10A merge suggestion adapter.
    Returns ranked possible cluster pairs.
    """
    try:
        suggestions = []
        source = getattr(self, "people_data", None) or getattr(self, "clusters", None) or []

        normalized = []
        for item in list(source):
            if not isinstance(item, dict):
                continue
            pid = item.get("id") or item.get("person_id") or item.get("label")
            label = item.get("label") or item.get("name") or str(pid)
            count = int(item.get("count", 0))
            samples = list(item.get("samples", []) or [])[:5]

            if pid is not None:
                normalized.append({
                    "id": str(pid),
                    "label": str(label),
                    "count": count,
                    "samples": samples,
                })

        normalized = sorted(normalized, key=lambda x: x["count"])

        for i in range(min(len(normalized) - 1, 20)):
            left = normalized[i]
            for j in range(i + 1, min(i + 4, len(normalized))):
                right = normalized[j]

                if left["id"] == right["id"]:
                    continue

                score = 0.0

                # Lightweight heuristics only
                if left["count"] <= 3:
                    score += 0.20
                if right["count"] <= 5:
                    score += 0.15
                if left["label"].lower().startswith("face_"):
                    score += 0.10
                if right["label"].lower().startswith("face_"):
                    score += 0.10

                if score >= 0.35:
                    suggestions.append({
                        "left_id": left["id"],
                        "right_id": right["id"],
                        "left_label": left["label"],
                        "right_label": right["label"],
                        "left_samples": left["samples"],
                        "right_samples": right["samples"],
                        "score": score,
                        "reason": "Small / unnamed clusters with likely overlap.",
                        "label": f"{left['label']} ↔ {right['label']}",
                    })

        suggestions = sorted(suggestions, key=lambda x: x.get("score", 0), reverse=True)
        return suggestions[:12]

    except Exception:
        return []
